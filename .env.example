# MongoDB connection (server-only)
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.example.mongodb.net
MONGODB_DB=messmass

# Admin auth (server-only; never client-exposed)
ADMIN_PASSWORD=

# SSO service base URL (server-only; base URL only, no tokens)
SSO_BASE_URL=https://sso.example.com

# Application URLs
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api

# Client-exposed URLs (only NEXT_PUBLIC_* keys are available in the browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:7654

# Bitly API integration (server-only)
# Get your access token from: https://bitly.com/a/settings/api
BITLY_ACCESS_TOKEN=
# Optional: Organization/Group GUID to restrict API calls to specific workspace
BITLY_ORGANIZATION_GUID=

# Football-Data.org API integration (server-only)
# WHAT: Required for fixture scheduling and team enrichment
# WHY: Enables automatic event creation from scheduled matches and enhanced partner KYC
FOOTBALL_DATA_API_TOKEN=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_SYNC_INTERVAL_HOURS=6
FOOTBALL_DATA_AUTO_CREATE_PROJECTS=true
FOOTBALL_DATA_AUTO_CREATE_PARTNERS=true

# SMTP email (server-only) — transactional email (admin password regeneration, config self-test)
# WHAT: Required for lib/emailNotifications.ts to send. If SMTP_USER/SMTP_PASS are
#       unset, createTransporter() throws and password-reset emails fail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# EMAIL_FROM is an accepted fallback for SMTP_FROM
EMAIL_FROM=

# Cron authorization (server-only)
# WHAT: Shared secret required by scheduled endpoints (e.g. /api/cron/google-sheets-sync).
# WHY: If unset the cron route currently allows unauthenticated triggers — set it in production.
CRON_SECRET=

# Security hardening flags (server-only)
# WHAT: Mandatory for production readiness (OPS-SEC-01)
# WHY: Protect user data, sessions, and prevent code injection
ENABLE_BCRYPT_AUTH=false
ENABLE_JWT_SESSIONS=false
ENABLE_HTML_SANITIZATION=false
ENABLE_SAFE_FORMULA_PARSER=false

# JWT Secret (server-only)
# WHAT: Cryptographic secret for signing session tokens
# WHY: Prevents token tampering when ENABLE_JWT_SESSIONS=true
# REQUIREMENT: Minimum 32 characters in production
JWT_SECRET=

# Security guidance:
# - Do NOT commit real secrets.
# - Keep secrets in environment providers; never in DB unless an approved encryption scheme exists.
# - Client-visible values MUST use NEXT_PUBLIC_*.
# - In production, all ENABLE_*_SECURITY flags MUST be set to true.
